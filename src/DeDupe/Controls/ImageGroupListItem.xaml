<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DeDupe.Controls.ImageGroupListItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:DeDupe.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DeDupe.Models.Analysis"
    d:DataContext="{d:DesignInstance Type=models:SimilarityGroup}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:SimilarityToPercentageConverter x:Key="SimilarityToPercentageConverter" />
    </UserControl.Resources>

    <Border
        Padding="20,6,10,6"
        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="6"
        PointerPressed="OnCardPointerPressed">
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Selection Checkbox  -->
            <CheckBox
                x:Name="GroupSelectionCheckBox"
                Grid.Column="0"
                MinWidth="0"
                MinHeight="0"
                Padding="0"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4"
                IsChecked="{x:Bind Group.IsSelected, Mode=TwoWay}"
                IsThreeState="True" />

            <!--  Thumbnails  -->
            <Border
                Grid.Column="1"
                Width="60"
                Height="48"
                VerticalAlignment="Center"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="4">
                <Grid>
                    <Grid x:Name="StackedThumbnails" Margin="5,5,10,10" />

                    <!--  Placeholder  -->
                    <FontIcon
                        x:Name="PlaceholderIcon"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Glyph="&#xEB9F;" />
                </Grid>
            </Border>

            <!--  Group Name  -->
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Center"
                FontSize="14"
                Text="{x:Bind Group.Name, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />

            <!--  Image Count  -->
            <StackPanel
                Grid.Column="3"
                Orientation="Horizontal"
                Spacing="4">
                <FontIcon
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Glyph="&#xE8B9;" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold">
                    <Run Text="{x:Bind Group.Count, Mode=OneWay}" />
                    <Run
                        l:Localization.Uid="ImageGroupCard_ImagesLabel"
                        FontSize="12"
                        FontWeight="Normal"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </TextBlock>
            </StackPanel>

            <!--  Similarity Badge  -->
            <Border
                Grid.Column="4"
                Padding="8,3"
                VerticalAlignment="Center"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="4">
                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextOnAccentFillColorDefaultBrush}"
                    Text="{x:Bind Group.AverageSimilarity, Mode=OneWay, Converter={StaticResource SimilarityToPercentageConverter}}" />
            </Border>

            <!--  Selection Count Badge  -->
            <Border
                Grid.Column="5"
                MinWidth="24"
                Padding="2,4"
                VerticalAlignment="Center"
                Background="{ThemeResource AccentDark2Brush}"
                CornerRadius="10"
                Visibility="{x:Bind Group.IsAnySelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AccentLight3Brush}"
                    Text="{x:Bind Group.SelectedCount, Mode=OneWay}" />
            </Border>
        </Grid>
    </Border>
</UserControl>
