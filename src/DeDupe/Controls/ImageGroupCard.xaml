<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DeDupe.Controls.ImageGroupCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DeDupe.Models.Analysis"
    d:DataContext="{d:DesignInstance Type=models:SimilarityGroup}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:SimilarityToPercentageConverter x:Key="SimilarityToPercentageConverter" />
    </UserControl.Resources>
    <Border
        Width="280"
        Height="260"
        Padding="10"
        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8"
        PointerPressed="OnCardPointerPressed">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Thumbnails  -->
            <Grid Grid.Row="0">
                <Grid x:Name="StackedThumbnails" Margin="10,10,50,50" />

                <!--  Selection Checkbox  -->
                <CheckBox
                    x:Name="GroupSelectionCheckBox"
                    MinWidth="0"
                    MinHeight="0"
                    Margin="4"
                    Padding="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="4"
                    IsChecked="{x:Bind Group.IsSelected, Mode=TwoWay}"
                    IsThreeState="True" />

                <!--  Selection Count Badge  -->
                <Border
                    Margin="4"
                    Padding="6,2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{ThemeResource SystemFillColorCriticalBrush}"
                    CornerRadius="10"
                    Visibility="{x:Bind Group.IsAnySelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="{x:Bind Group.SelectedCount, Mode=OneWay}" />
                </Border>
            </Grid>

            <!--  Group Info  -->
            <StackPanel Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="4">
                        <!--  Group Name  -->
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind Group.Name, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />

                        <!--  Image Count  -->
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon
                                FontSize="16"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE8B9;" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                                <Run Text="{x:Bind Group.Count, Mode=OneWay}" />
                                <Run
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text=" images" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!--  Similarity Badge  -->
                    <Border
                        Grid.Column="1"
                        Padding="8,4"
                        VerticalAlignment="Bottom"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextOnAccentFillColorDefaultBrush}"
                            Text="{x:Bind Group.AverageSimilarity, Mode=OneWay, Converter={StaticResource SimilarityToPercentageConverter}}" />
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>