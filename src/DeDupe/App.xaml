<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="DeDupe.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!--  Accent Color Brushes  -->
            <SolidColorBrush x:Key="AccentBaseBrush" Color="{ThemeResource SystemAccentColor}" />
            <SolidColorBrush x:Key="AccentLight1Brush" Color="{ThemeResource SystemAccentColorLight1}" />
            <SolidColorBrush x:Key="AccentLight2Brush" Color="{ThemeResource SystemAccentColorLight2}" />
            <SolidColorBrush x:Key="AccentLight3Brush" Color="{ThemeResource SystemAccentColorLight3}" />
            <SolidColorBrush x:Key="AccentDark1Brush" Color="{ThemeResource SystemAccentColorDark1}" />
            <SolidColorBrush x:Key="AccentDark2Brush" Color="{ThemeResource SystemAccentColorDark2}" />
            <SolidColorBrush x:Key="AccentDark3Brush" Color="{ThemeResource SystemAccentColorDark3}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>