<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Pages.ModelConfigurationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    d:DataContext="{d:DesignInstance Type=pages:ModelConfigurationViewModel}"
    mc:Ignorable="d">
    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title  -->
        <StackPanel
            Grid.Row="0"
            Margin="5,0"
            Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Select an pre trained model to analyze your images."
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  Main Content  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="5">
                <!--  Model Selection  -->
                <TextBlock
                    Margin="0,0,0,3"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Model Selection" />

                <!--  Model File  -->
                <controls:SettingsExpander
                    VerticalAlignment="Top"
                    Description="Supported format: ONNX (.onnx)"
                    Header="Select Model File"
                    HeaderIcon="{ui:FontIcon Glyph=&#xF003;}"
                    IsExpanded="True">
                    <!--  Drag and Drop Container for Model File  -->
                    <Grid
                        x:Name="ModelFileDropGrid"
                        AllowDrop="True"
                        ColumnSpacing="5"
                        DragOver="ModelFileDropGrid_DragOver"
                        Drop="ModelFileDropGrid_Drop">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            MinWidth="300"
                            MinHeight="32"
                            Padding="12,5,12,6"
                            Background="{ThemeResource TextControlBackground}"
                            BorderBrush="{ThemeResource TextControlBorderBrush}"
                            BorderThickness="{ThemeResource TextControlBorderThemeThickness}"
                            CornerRadius="{ThemeResource ControlCornerRadius}"
                            DoubleTapped="ModelFileTextBlock_DoubleTapped"
                            ToolTipService.ToolTip="Double-click to open in Explorer">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextControlForeground}"
                                TextTrimming="CharacterEllipsis"
                                ToolTipService.ToolTip="{x:Bind ViewModel.ModelFilePath, Mode=OneWay}">
                                <Run
                                    FontSize="11"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.DirectoryPath, Mode=OneWay}" />
                                <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.FileName, Mode=OneWay}" />
                            </TextBlock>
                        </Border>
                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            AllowDrop="True"
                            Command="{x:Bind ViewModel.SelectModelFileCommand}"
                            ToolTipService.ToolTip="Browse for model file">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xED25;" />
                        </Button>
                    </Grid>

                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard Description="(Recommended: resnet50-v2-7.onnx)" Header="Download Pre-trained Models">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <HyperlinkButton NavigateUri="https://huggingface.co/webml/models-moved/tree/main" ToolTipService.ToolTip="https://huggingface.co/webml/models-moved/tree/main">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon
                                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                                            FontSize="14"
                                            Glyph="&#xE8A7;" />
                                        <TextBlock Text="Download from HuggingFace" />
                                    </StackPanel>
                                </HyperlinkButton>
                                <HyperlinkButton NavigateUri="https://github.com/onnx/models/tree/main/validated/vision/classification/resnet/model" ToolTipService.ToolTip="https://github.com/onnx/models/tree/main/validated/vision/classification/resnet/model">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon
                                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                                            FontSize="14"
                                            Glyph="&#xE8A7;" />
                                        <TextBlock Text="Download from GitHub" />
                                    </StackPanel>
                                </HyperlinkButton>
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!--  Model Configuration  -->
                <TextBlock
                    Margin="0,29,0,3"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Model Configuration" />

                <!--  Normalization Settings  -->
                <controls:SettingsExpander
                    VerticalAlignment="Top"
                    Description="Advanced color value adjustments. Most users should keep the defaults."
                    Header="Normalization Settings"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE713;}">
                    <Button
                        HorizontalAlignment="Right"
                        Command="{x:Bind ViewModel.ResetNormalizationCommand}"
                        Content="Reset to Default"
                        Style="{StaticResource DefaultButtonStyle}"
                        ToolTipService.ToolTip="Reset to ImageNet normalization values" />

                    <controls:SettingsExpander.Items>
                        <!--  Mean  -->
                        <controls:SettingsCard Description="R, G, B" Header="Mean Values">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <NumberBox
                                    BorderBrush="Red"
                                    LargeChange="0.01"
                                    PlaceholderText="0.485"
                                    SmallChange="0.001"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.MeanR, Mode=TwoWay}" />

                                <NumberBox
                                    BorderBrush="Green"
                                    LargeChange="0.01"
                                    PlaceholderText="0.456"
                                    SmallChange="0.001"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.MeanG, Mode=TwoWay}" />

                                <NumberBox
                                    BorderBrush="Blue"
                                    LargeChange="0.01"
                                    PlaceholderText="0.406"
                                    SmallChange="0.001"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.MeanB, Mode=TwoWay}" />
                            </StackPanel>
                        </controls:SettingsCard>

                        <!--  Standard Deviation  -->
                        <controls:SettingsCard Description="R, G, B" Header="Standard Deviation Values">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <NumberBox
                                    BorderBrush="Red"
                                    LargeChange="0.01"
                                    PlaceholderText="0.229"
                                    SmallChange="0.001"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.StdR, Mode=TwoWay}" />

                                <NumberBox
                                    BorderBrush="Green"
                                    LargeChange="0.01"
                                    PlaceholderText="0.224"
                                    SmallChange="0.001"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.StdG, Mode=TwoWay}" />

                                <NumberBox
                                    BorderBrush="Blue"
                                    LargeChange="0.01"
                                    PlaceholderText="0.225"
                                    SmallChange="0.001"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.StdB, Mode=TwoWay}" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>
            </StackPanel>
        </ScrollViewer>

        <!--  Navigation Buttons  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                HorizontalAlignment="Left"
                Command="{x:Bind ViewModel.NavigateToPreviousCommand}"
                Content="Previous" />

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">

                <!--  Progress and Status  -->
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                    TextWrapping="Wrap" />

                <Button
                    Command="{x:Bind ViewModel.ExtractFeaturesCommand}"
                    Content="Extract Features"
                    IsEnabled="{x:Bind ViewModel.CanStartExtraction, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}" />

                <Button
                    Command="{x:Bind ViewModel.NavigateToManagementPageCommand}"
                    Content="View Similar Images"
                    IsEnabled="{x:Bind ViewModel.CanCloseConfiguration, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>