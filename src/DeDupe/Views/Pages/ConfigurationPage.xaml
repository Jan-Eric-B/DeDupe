<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Pages.ConfigurationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:input="using:DeDupe.Models.Input"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    d:DataContext="{d:DesignInstance Type=pages:ConfigurationViewModel}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title  -->
        <StackPanel
            Grid.Row="0"
            Margin="5,0"
            Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Add multiple files or whole folders you want to scan for duplicates and similar images."
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  Item List  -->
        <ListView
            x:Name="LvInputList"
            Grid.Row="1"
            Padding="0,5"
            AllowDrop="True"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            DragOver="LvInputList_DragOver"
            Drop="LvInputList_Drop"
            ItemsSource="{x:Bind ViewModel.InputListItems, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="input:InputListItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Item Icon  -->
                        <FontIcon
                            Grid.Column="0"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Glyph="{x:Bind IconGlyph, Mode=OneWay}" />

                        <!--  Item Path  -->
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="{x:Bind Path}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap"
                            ToolTipService.ToolTip="{x:Bind Path}" />

                        <!--  Include Subdirectories Checkbox - Only visible for folders with subdirectories  -->
                        <CheckBox
                            Grid.Column="2"
                            Margin="10,0"
                            VerticalAlignment="Center"
                            Content="Include subfolders"
                            IsChecked="{x:Bind IncludeSubdirectories, Mode=TwoWay}"
                            ToolTipService.ToolTip="Scan all nested directories for images"
                            Visibility="{x:Bind ShowSubdirectoriesCheckbox}" />
                        <!--  Remove Button  -->

                        <Button
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ElementName=LvInputList, Path=DataContext.RemoveItemCommand}"
                            CommandParameter="{Binding}"
                            IsEnabled="{Binding ElementName=LvInputList, Path=DataContext.IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            ToolTipService.ToolTip="Remove item">
                            <FontIcon Glyph="&#xE74D;" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

            <!--  Empty state message  -->
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsHitTestVisible="False"
            Spacing="16"
            Visibility="{x:Bind ViewModel.IsMediaListEmpty, Mode=OneWay}">
            <FontIcon
                FontSize="72"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Glyph="&#xE8B7;" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Drag and drop files or folders here" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="or use the buttons below to select files" />
        </StackPanel>

        <!--  Bottom Action Bar  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Status Text with Progress Indicator  -->
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">

                <!--  Progress Ring  -->
                <ProgressRing
                    Width="16"
                    Height="16"
                    IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!--  Action Buttons  -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8">

                <!--  Cancel Scan Button  -->
                <Button
                    Command="{x:Bind ViewModel.CancelScanCommand}"
                    Content="Cancel"
                    ToolTipService.ToolTip="Cancel folder scanning"
                    Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!--  File Input Buttons  -->
                <Button
                    Command="{x:Bind ViewModel.AddFolderCommand}"
                    Content="Add Folders"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />
                <Button
                    Command="{x:Bind ViewModel.AddFilesCommand}"
                    Content="Add Files"
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}" />

                <!--  Separator  -->
                <Border
                    Width="1"
                    Margin="4,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!--  Combined Process Button (Preprocess + Extract Features)  -->
                <Button
                    Command="{x:Bind ViewModel.ProcessCommand}"
                    Content="Process"
                    IsEnabled="{x:Bind ViewModel.CanStartProcessing, Mode=OneWay}"
                    ToolTipService.ToolTip="Preprocess images and extract feature vectors" />

                <!--  Separator  -->
                <Border
                    Width="1"
                    Margin="4,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!--  Navigation Button  -->
                <Button
                    Command="{x:Bind ViewModel.NavigateToNextCommand}"
                    Content="Find Duplicates"
                    IsEnabled="{x:Bind ViewModel.CanNavigateToNext, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Go to duplicate management (requires processed files)" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>