<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Pages.PreProcessingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="using:DeDupe.Enums"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    xmlns:ui="using:CommunityToolkit.WinUI"
    d:DataContext="{d:DesignInstance Type=pages:PreProcessingViewModel}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
        <Style x:Key="CustomColorPickerStyle" TargetType="ColorPicker">
            <Setter Property="IsAlphaEnabled" Value="False" />
            <Setter Property="IsAlphaSliderVisible" Value="False" />
            <Setter Property="IsColorSliderVisible" Value="True" />
            <Setter Property="IsColorChannelTextInputVisible" Value="False" />
            <Setter Property="IsColorSpectrumVisible" Value="True" />
            <Setter Property="ColorSpectrumShape" Value="Ring" />
        </Style>
    </Page.Resources>

    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title  -->
        <StackPanel
            Grid.Row="0"
            Margin="5,0"
            Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Configure how images are prepared for analysis. Can be left alone most of the time."
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  Main Content  -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="5">
                <!--  Resize Settings  -->
                <TextBlock
                    Margin="0,0,0,3"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Resize Settings" />

                <!--  Enable Resize  -->
                <controls:SettingsCard Header="Resize Image" HeaderIcon="{ui:FontIcon Glyph=&#xE799;}">
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.EnableResizing, Mode=TwoWay}"
                        OffContent="Off"
                        OnContent="On" />
                </controls:SettingsCard>

                <!--  Size  -->
                <controls:SettingsCard
                    Description="Width × Height (px)"
                    Header="Target Size"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE9A6;}"
                    IsEnabled="{x:Bind ViewModel.IsResizeEnabled, Mode=OneWay}">
                    <NumberBox
                        x:Name="ResizeSizeNumberBox"
                        Maximum="2048"
                        Minimum="32"
                        SpinButtonPlacementMode="Compact"
                        Value="{x:Bind ViewModel.ResizeSize, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!--  Method  -->
                <controls:SettingsCard
                    Description="How to handle images that don't match the target aspect ratio"
                    Header="Aspect Ratio Handling"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE740;}"
                    IsEnabled="{x:Bind ViewModel.IsResizeEnabled, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <controls:ColorPickerButton
                            ColorPickerStyle="{StaticResource CustomColorPickerStyle}"
                            SelectedColor="{x:Bind ViewModel.PaddingColor, Mode=TwoWay}"
                            Visibility="{x:Bind ViewModel.IsPaddingColorVisible, Mode=OneWay}" />

                        <ComboBox
                            x:Name="ResizeMethodComboBox"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            ItemsSource="{x:Bind ViewModel.ResizeMethods}"
                            SelectedItem="{x:Bind ViewModel.ResizeMethod, Mode=TwoWay}" />
                    </StackPanel>
                </controls:SettingsCard>

                <!--  Interpolation Methods  -->
                <controls:SettingsExpander
                    VerticalAlignment="Top"
                    Description="Used algorithm when images are scaled up or down"
                    Header="Interpolation Methods"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE158;}">
                    <controls:SettingsExpander.Items>

                        <!--  Upsampling  -->
                        <controls:SettingsCard
                            Header="Upsampling"
                            HeaderIcon="{ui:FontIcon Glyph=&#xEE47;}"
                            IsEnabled="{x:Bind ViewModel.IsInterpolationMethodsEnabled, Mode=OneWay}">
                            <ComboBox
                                x:Name="UpsamplingComboBox"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.InterpolationMethods}"
                                SelectedItem="{x:Bind ViewModel.UpsamplingMethod, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="enums:InterpolationMethod">
                                        <TextBlock Text="{x:Bind Converter={StaticResource EnumDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </controls:SettingsCard>

                        <!--  Downsampling  -->
                        <controls:SettingsCard
                            Header="Downsampling"
                            HeaderIcon="{ui:FontIcon Glyph=&#xEE49;}"
                            IsEnabled="{x:Bind ViewModel.IsInterpolationMethodsEnabled, Mode=OneWay}">
                            <ComboBox
                                x:Name="DownsamplingComboBox"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.InterpolationMethods}"
                                SelectedItem="{x:Bind ViewModel.DownsamplingMethod, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="enums:InterpolationMethod">
                                        <TextBlock Text="{x:Bind Converter={StaticResource EnumDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!--  Border Detection  -->
                <TextBlock
                    Margin="0,29,0,3"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Border Detection" />

                <!--  Enable Border Removal  -->
                <controls:SettingsCard
                    Description="Try to crop black bars or uniform borders from Images"
                    Header="Remove Borders/Letterboxing"
                    HeaderIcon="{ui:FontIcon Glyph=&#xEF2E;}">
                    <ToggleSwitch
                        x:Name="BorderDetectionCheckBox"
                        IsOn="{x:Bind ViewModel.EnableBorderDetection, Mode=TwoWay}"
                        OffContent="Off"
                        OnContent="On" />
                </controls:SettingsCard>

                <!--  Color Tolerance  -->
                <controls:SettingsCard
                    Description="How much color variation to allow (0-255)"
                    Header="Color Tolerance"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE790;}"
                    IsEnabled="{x:Bind ViewModel.EnableBorderDetection, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Slider
                            Width="150"
                            Maximum="255"
                            Minimum="0"
                            StepFrequency="1"
                            ToolTipService.ToolTip="Lower values: uniform borders / Higher values: borders with more color variation"
                            Value="{x:Bind ViewModel.BorderDetectionTolerance, Mode=TwoWay}" />
                        <TextBlock
                            Width="25"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.BorderDetectionTolerance, Mode=OneWay}" />
                    </StackPanel>
                </controls:SettingsCard>

                <!--  Output Settings  -->
                <TextBlock
                    Margin="0,29,0,3"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Output Settings" />

                <!--  File Format  -->
                <controls:SettingsCard Header="File Format" HeaderIcon="{ui:FontIcon Glyph=&#xE91B;}">
                    <ComboBox
                        x:Name="OutputFormatComboBox"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.OutputFormats}"
                        SelectedItem="{x:Bind ViewModel.OutputFormat, Mode=TwoWay}" />
                </controls:SettingsCard>

                <!--  Bit Depth  -->
                <controls:SettingsCard Header="Bit Depth" HeaderIcon="{ui:FontIcon Glyph=&#xEB9F;}">
                    <ComboBox
                        x:Name="BitDepthComboBox"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.BitDepths}"
                        SelectedItem="{x:Bind ViewModel.BitDepth, Mode=TwoWay}" />
                </controls:SettingsCard>
            </StackPanel>
        </ScrollViewer>

        <!--  Navigation Buttons  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                HorizontalAlignment="Left"
                Command="{x:Bind ViewModel.NavigateToPreviousCommand}"
                Content="Previous" />

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="10">

                <!--  Progress and Status  -->
                <ProgressRing x:Name="ProgressRing" IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

                <TextBlock
                    x:Name="StatusLabel"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                    TextWrapping="Wrap" />

                <!--  Process Button  -->
                <Button
                    x:Name="ProcessButton"
                    Command="{x:Bind ViewModel.ProcessImagesCommand}"
                    Content="Apply Preprocessing"
                    IsEnabled="{x:Bind ViewModel.CanStartProcessing, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}" />

                <!--  Open Output Folder Button  -->
                <Button
                    x:Name="OpenTempFolderButton"
                    Command="{x:Bind ViewModel.OpenTempFolderCommand}"
                    Content="Open Output Folder"
                    IsEnabled="{x:Bind ViewModel.CanOpenTempFolder, Mode=OneWay}" />
                <Button
                    Command="{x:Bind ViewModel.NavigateToNextCommand}"
                    Content="Next"
                    IsEnabled="{x:Bind ViewModel.CanNavigateToNext, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>