<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Pages.ManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DeDupe.Controls"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="using:DeDupe.Enums"
    xmlns:helpers="using:DeDupe.Helper"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DeDupe.Models.Analysis"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    xmlns:splitter="using:CommunityToolkit.WinUI.Controls"
    d:DataContext="{d:DesignInstance Type=pages:ManagementViewModel}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:EnumDescriptionConverter x:Key="EnumDescriptionConverter" />
        <converters:SimilarityToPercentageConverter x:Key="SimilarityToPercentageConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <Style x:Key="CustomGridSplitterStyle" TargetType="splitter:GridSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="splitter:GridSplitter">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.4*" />
                                    <RowDefinition Height="0.2*" />
                                    <RowDefinition Height="0.4*" />
                                </Grid.RowDefinitions>

                                <Rectangle
                                    x:Name="GripperBar"
                                    Grid.Row="1"
                                    Width="4"
                                    Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    Opacity="0.3"
                                    RadiusX="2"
                                    RadiusY="2" />
                            </Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="GripperBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="GripperBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Name="ShowGroupContentPanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanelTransform"
                Storyboard.TargetProperty="X"
                To="0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanel"
                Storyboard.TargetProperty="Opacity"
                To="1"
                Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Name="HideGroupContentPanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanelTransform"
                Storyboard.TargetProperty="X"
                To="400"
                Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanel"
                Storyboard.TargetProperty="Opacity"
                To="0"
                Duration="0:0:0.25" />
        </Storyboard>
    </Page.Resources>

    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <Border
            Grid.Row="0"
            Margin="10,0"
            Padding="16,12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            CornerRadius="8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Auto-Selection  -->
                <DropDownButton
                    Grid.Column="0"
                    IsEnabled="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}"
                    ToolTipService.ToolTip="Apply auto selection to all groups">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xF16E;" />
                        <TextBlock Text="Auto-Select All" />
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">

                            <MenuFlyoutSubItem Text="By Resolution">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon Glyph="&#xE9E9;" />
                                </MenuFlyoutSubItem.Icon>
                                <MenuFlyoutItem Click="ApplyStrategyToAll_KeepHighestResolution" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepHighestResolution)}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9E9;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="ApplyStrategyToAll_KeepLowestResolution" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepLowestResolution)}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9E9;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyoutSubItem>

                            <MenuFlyoutSubItem Text="By File Size">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon Glyph="&#xE729;" />
                                </MenuFlyoutSubItem.Icon>
                                <MenuFlyoutItem Click="ApplyStrategyToAll_KeepLargestFileSize" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepLargestFileSize)}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE729;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="ApplyStrategyToAll_KeepSmallestFileSize" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepSmallestFileSize)}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE729;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyoutSubItem>

                            <MenuFlyoutSubItem Text="By Date">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon Glyph="&#xE787;" />
                                </MenuFlyoutSubItem.Icon>
                                <MenuFlyoutItem Click="ApplyStrategyToAll_KeepNewest" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepNewest)}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE823;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="ApplyStrategyToAll_KeepOldest" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepOldest)}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74B;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyoutSubItem>

                            <MenuFlyoutSeparator />

                            <MenuFlyoutItem Click="SelectAllCheckBox_Click" Text="Select All">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE73A;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>

                            <MenuFlyoutItem Click="ClearAllSelections_Click" Text="Clear All">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE739;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <!--  Sort Dropdown  -->
                <DropDownButton
                    Grid.Column="1"
                    IsEnabled="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}"
                    ToolTipService.ToolTip="Sort duplicate groups">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE8CB;" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentSortOption, Mode=OneWay, Converter={StaticResource EnumDescriptionConverter}}" />
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Click="SortBy_Similarity" Text="Similarity (High to Low)">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE9D9;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Click="SortBy_ImageCount" Text="Image Count">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B9;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Click="SortBy_Name" Text="Group Name">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8AC;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <!--  Separator  -->
                <Border
                    Grid.Column="2"
                    Width="1"
                    Margin="4,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!--  Spacer  -->
                <Border Grid.Column="3" />

                <!--  Similarity Threshold  -->
                <StackPanel
                    Grid.Column="4"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Similarity Threshold:" />
                    <Slider
                        x:Name="SimilaritySlider"
                        Width="100"
                        VerticalAlignment="Center"
                        Maximum="1.0"
                        Minimum="0.3"
                        StepFrequency="0.01"
                        ThumbToolTipValueConverter="{StaticResource SimilarityToPercentageConverter}"
                        ToolTipService.ToolTip="How similar images must be to be grouped"
                        Value="{x:Bind ViewModel.SimilarityThreshold, Mode=TwoWay}" />
                    <TextBlock
                        Width="40"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.SimilarityThreshold, Mode=OneWay, Converter={StaticResource SimilarityToPercentageConverter}}" />
                    <Button
                        Command="{x:Bind ViewModel.AnalyzeSimilarityCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        ToolTipService.ToolTip="Re-analyze with current threshold">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE9D9;" />
                            <TextBlock Text="Analyze" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Separator  -->
                <Border
                    Grid.Column="5"
                    Width="1"
                    Margin="4,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!--  Config Info  -->
                <StackPanel
                    Grid.Column="6"
                    Orientation="Horizontal"
                    Spacing="12">

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="12"
                        ToolTipService.ToolTip="Item Count">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon
                                FontSize="14"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE8B8;" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Text="{x:Bind ViewModel.ModelName, Mode=OneWay}"
                                ToolTipService.ToolTip="AI Model" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon
                                FontSize="14"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE8B9;" />
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                <Run Text="{x:Bind ViewModel.TotalFileCount, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!--  Back to Config Button  -->
                    <Button Click="BackToConfiguration_Click" ToolTipService.ToolTip="Back to configuration">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE72B;" />
                            <TextBlock Text="Configuration" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Main Content  -->
        <Grid
            x:Name="SplitViewGrid"
            Grid.Row="1"
            Margin="10,10,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <!--  Left Panel - Cluster Grid  -->
            <Border
                Grid.Column="0"
                MinWidth="300"
                Padding="16"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,16"
                        Spacing="4">
                        <TextBlock FontSize="20" FontWeight="SemiBold">
                            <Run Text="Duplicate Groups" />
                            <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" (" /><Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.DuplicateGroupsCount, Mode=OneWay}" /><Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=")" />
                        </TextBlock>
                        <TextBlock
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.Status, Mode=OneWay}" />
                    </StackPanel>

                    <!--  Empty State  -->
                    <StackPanel
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay}">
                        <FontIcon
                            FontSize="64"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Glyph="&#xE8B9;" />
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="No Results Yet" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="Adjust the similarity threshold and click Analyze"
                                TextAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Cluster Grid  -->
                    <ScrollViewer Grid.Row="1" Visibility="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}">
                        <GridView
                            IsItemClickEnabled="True"
                            ItemsSource="{x:Bind ViewModel.ClusterGroups, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedCluster, Mode=TwoWay}"
                            SelectionMode="Single">
                            <GridView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource DefaultGridViewItemStyle}" TargetType="GridViewItem">
                                    <Setter Property="Margin" Value="4" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:SimilarityGroup">
                                    <controls:ImageGroupCard Group="{x:Bind}" />
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!--  GridSplitter  -->
            <splitter:GridSplitter
                x:Name="GroupContentSplitter"
                Grid.Column="1"
                Width="16"
                HorizontalAlignment="Center"
                Background="Transparent"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Auto"
                Style="{StaticResource CustomGridSplitterStyle}"
                Visibility="{x:Bind ViewModel.SelectedCluster, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

            <!--  Right Panel - Group Content  -->
            <Border
                x:Name="GroupContentPanel"
                Grid.Column="2"
                MinWidth="400"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Opacity="0"
                Visibility="{x:Bind ViewModel.SelectedCluster, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="GroupContentPanelTransform" X="400" />
                </Border.RenderTransform>

                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Editable Group Name  -->
                        <Grid Grid.Column="0">
                            <!--  Display Mode  -->
                            <StackPanel
                                x:Name="GroupNameDisplayPanel"
                                Orientation="Horizontal"
                                Spacing="8">
                                <TextBlock
                                    x:Name="GroupNameTextBlock"
                                    Padding="0,3.5"
                                    VerticalAlignment="Center"
                                    DoubleTapped="GroupNameTextBlock_DoubleTapped"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.SelectedCluster.Name, Mode=OneWay}"
                                    ToolTipService.ToolTip="Double-click to rename" />
                                <Button
                                    x:Name="EditGroupNameButton"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    Click="EditGroupNameButton_Click"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Rename group">
                                    <FontIcon FontSize="12" Glyph="&#xE70F;" />
                                </Button>
                            </StackPanel>

                            <!--  Edit Mode  -->
                            <StackPanel
                                x:Name="GroupNameEditPanel"
                                Orientation="Horizontal"
                                Spacing="4"
                                Visibility="Collapsed">
                                <TextBox
                                    x:Name="GroupNameTextBox"
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    KeyDown="GroupNameTextBox_KeyDown"
                                    LostFocus="GroupNameTextBox_LostFocus"
                                    PlaceholderText="Enter group name" />
                                <Button
                                    x:Name="ConfirmRenameButton"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    Click="ConfirmRenameButton_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="Confirm (Enter)">
                                    <FontIcon FontSize="12" Glyph="&#xE8FB;" />
                                </Button>
                                <Button
                                    x:Name="CancelRenameButton"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    Click="CancelRenameButton_Click"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Cancel (Escape)">
                                    <FontIcon FontSize="12" Glyph="&#xE711;" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!--  Close Button  -->
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            Click="CloseGroupContentPanel_Click"
                            Style="{StaticResource SubtleButtonStyle}"
                            ToolTipService.ToolTip="Close details">
                            <FontIcon FontSize="16" Glyph="&#xE711;" />
                        </Button>
                    </Grid>

                    <!--  Selection Controls  -->
                    <Border
                        Grid.Row="1"
                        Padding="12"
                        Background="{ThemeResource LayerFillColorAltBrush}"
                        CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Select All Checkbox  -->
                            <CheckBox
                                x:Name="SelectAllCheckBox"
                                Grid.Column="0"
                                MinWidth="0"
                                MinHeight="0"
                                VerticalAlignment="Center"
                                Click="SelectAllGroupCheckBox_Click"
                                IsThreeState="True"
                                ToolTipService.ToolTip="Select/deselect all in this group" />

                            <!--  Selection Count  -->
                            <TextBlock
                                x:Name="SelectionCountText"
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <!--  Auto-Select Dropdown  -->
                            <DropDownButton Grid.Column="2" ToolTipService.ToolTip="Auto selection for this group">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xF16E;" />
                                    <TextBlock Text="Auto-Select" />
                                </StackPanel>
                                <DropDownButton.Flyout>
                                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                                        <MenuFlyoutSubItem Text="By Resolution">
                                            <MenuFlyoutSubItem.Icon>
                                                <FontIcon Glyph="&#xE9E9;" />
                                            </MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem Click="ApplyStrategy_KeepHighestResolution" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepHighestResolution                                                 )}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE9E9;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Click="ApplyStrategy_KeepLowestResolution" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepLowestResolution)}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE9E9;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyoutSubItem>

                                        <MenuFlyoutSubItem Text="By File Size">
                                            <MenuFlyoutSubItem.Icon>
                                                <FontIcon Glyph="&#xE729;" />
                                            </MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem Click="ApplyStrategy_KeepLargestFileSize" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepLargestFileSize)}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE729;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Click="ApplyStrategy_KeepSmallestFileSize" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepSmallestFileSize)}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE729;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyoutSubItem>

                                        <MenuFlyoutSubItem Text="By Date">
                                            <MenuFlyoutSubItem.Icon>
                                                <FontIcon Glyph="&#xE787;" />
                                            </MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem Click="ApplyStrategy_KeepNewest" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepNewest)}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE823;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Click="ApplyStrategy_KeepOldest" Text="{x:Bind helpers:EnumExtensions.GetDescription(enums:SelectionStrategy.KeepOldest)}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74B;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyoutSubItem>
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </Grid>
                    </Border>

                    <!--  Image Cards Grid  -->
                    <ScrollViewer Grid.Row="2">
                        <ItemsRepeater x:Name="ImageCardsRepeater" ItemsSource="{x:Bind ViewModel.SelectedCluster.SelectableItems, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout
                                    ItemsStretch="None"
                                    MinColumnSpacing="8"
                                    MinItemHeight="240"
                                    MinItemWidth="180"
                                    MinRowSpacing="8"
                                    Orientation="Horizontal" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:SelectableItem">
                                    <controls:ImageDetailCard SelectableItem="{x:Bind}" />
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!--  Bottom Action Bar  -->
        <Border
            Grid.Row="2"
            Margin="10,0,10,10"
            Padding="16,12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            CornerRadius="8"
            Visibility="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Left Side - Selection Summary  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="16">

                    <!--  Selection Info  -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon
                            FontSize="18"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Glyph="&#xE73E;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="{x:Bind ViewModel.SelectionSummary, Mode=OneWay}" />
                    </StackPanel>

                    <!--  Clear All Button  -->
                    <Button
                        Click="ClearAllSelections_Click"
                        Style="{StaticResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="Clear all selections"
                        Visibility="{x:Bind ViewModel.HasAnySelectedItems, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="12" Glyph="&#xE711;" />
                            <TextBlock Text="Clear All" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Right Side - Action Buttons  -->
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">

                    <!--  Copy  -->
                    <DropDownButton IsEnabled="{x:Bind ViewModel.CanMoveOrCopy, Mode=OneWay}" ToolTipService.ToolTip="Copy selected files to a folder">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                            <TextBlock Text="Copy" />
                        </StackPanel>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem Click="CopyToSingleFolder_Click" Text="Copy all to one folder...">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8C8;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="CopyToGroupFolders_Click" Text="Organize into group folders">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xF413;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <!--  Move  -->
                    <DropDownButton IsEnabled="{x:Bind ViewModel.CanMoveOrCopy, Mode=OneWay}" ToolTipService.ToolTip="Move selected files to a folder">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE8C6;" />
                            <TextBlock Text="Move" />
                        </StackPanel>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem Click="MoveToSingleFolder_Click" Text="Move all to one folder...">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8DE;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="MoveToGroupFolders_Click" Text="Organize into group folders">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xF413;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <!--  Separator  -->
                    <Border
                        Width="1"
                        Margin="4,4"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!--  Delete Button  -->
                    <SplitButton
                        x:Name="DeleteSelectedButton"
                        Click="DeleteSplitButton_Click"
                        IsEnabled="{x:Bind ViewModel.HasAnySelectedItems, Mode=OneWay}"
                        ToolTipService.ToolTip="Move selected files to Recycle Bin">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                            <TextBlock>
                                <Run Text="Delete" />
                                <Run Text="(" /><Run Text="{x:Bind ViewModel.TotalSelectedCount, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem Click="DeleteToRecycleBin_Click" Text="Move to Recycle Bin">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="DeletePermanently_Click" Text="Delete Permanently">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE894;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>