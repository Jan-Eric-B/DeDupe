<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Pages.ManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DeDupe.Controls"
    xmlns:controlsWinUI="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="using:DeDupe.Enums"
    xmlns:l="using:DeDupe.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DeDupe.Models.Analysis"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    xmlns:splitter="using:CommunityToolkit.WinUI.Controls"
    d:DataContext="{d:DesignInstance Type=pages:ManagementViewModel}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:SimilarityToPercentageConverter x:Key="SimilarityToPercentageConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:PercentageConverter x:Key="PercentageConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="CustomGridSplitterStyle" TargetType="splitter:GridSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="splitter:GridSplitter">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.4*" />
                                    <RowDefinition Height="0.2*" />
                                    <RowDefinition Height="0.4*" />
                                </Grid.RowDefinitions>

                                <Rectangle
                                    x:Name="GripperBar"
                                    Grid.Row="1"
                                    Width="2"
                                    Opacity="0" />
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Name="ShowGroupContentPanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanelTransform"
                Storyboard.TargetProperty="X"
                To="0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanel"
                Storyboard.TargetProperty="Opacity"
                To="1"
                Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Name="HideGroupContentPanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanelTransform"
                Storyboard.TargetProperty="X"
                To="400"
                Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanel"
                Storyboard.TargetProperty="Opacity"
                To="0"
                Duration="0:0:0.25" />
        </Storyboard>
    </Page.Resources>

    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <Border
            Grid.Row="0"
            Margin="10,0"
            Padding="16,12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            CornerRadius="8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Auto-Selection  -->
                <DropDownButton
                    Grid.Column="0"
                    l:Localization.Uid="ManagementPage_AutoSelectAllButton"
                    IsEnabled="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xF16E;" />
                        <TextBlock l:Localization.Uid="ManagementPage_AutoSelectAllText" />
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutSubItem l:Localization.Uid="ManagementPage_ByResolution">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon Glyph="&#xE9E9;" />
                                </MenuFlyoutSubItem.Icon>
                                <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepHighestResolution" Click="ApplyStrategyToAll_KeepHighestResolution">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9E9;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepLowestResolution" Click="ApplyStrategyToAll_KeepLowestResolution">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9E9;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyoutSubItem>

                            <MenuFlyoutSubItem l:Localization.Uid="ManagementPage_ByFileSize">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon Glyph="&#xE729;" />
                                </MenuFlyoutSubItem.Icon>
                                <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepLargestFileSize" Click="ApplyStrategyToAll_KeepLargestFileSize">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE729;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepSmallestFileSize" Click="ApplyStrategyToAll_KeepSmallestFileSize">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE729;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyoutSubItem>

                            <MenuFlyoutSubItem l:Localization.Uid="ManagementPage_ByDate">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon Glyph="&#xE787;" />
                                </MenuFlyoutSubItem.Icon>
                                <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepNewest" Click="ApplyStrategyToAll_KeepNewest">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE823;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepOldest" Click="ApplyStrategyToAll_KeepOldest">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74B;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyoutSubItem>

                            <MenuFlyoutSeparator />

                            <MenuFlyoutItem l:Localization.Uid="ManagementPage_SelectAllMenuItem" Click="SelectAllCheckBox_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE73A;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>

                            <MenuFlyoutItem l:Localization.Uid="ManagementPage_ClearAllMenuItem" Click="ClearAllSelections_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE739;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <!--  Sort Dropdown  -->
                <DropDownButton
                    Grid.Column="1"
                    l:Localization.Uid="ManagementPage_SortButton"
                    IsEnabled="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE8CB;" />
                        <TextBlock>
                            <Run l:Localization.Uid="ManagementPage_SortPrefix" />
                            <Run Text="{x:Bind ViewModel.CurrentSortOptionDisplay, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <RadioMenuFlyoutItem
                                l:Localization.Uid="ManagementPage_SortSimilarity"
                                Click="SortBy_Similarity"
                                GroupName="SortGroup"
                                IsChecked="True">
                                <RadioMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE9D9;" />
                                </RadioMenuFlyoutItem.Icon>
                            </RadioMenuFlyoutItem>
                            <RadioMenuFlyoutItem
                                l:Localization.Uid="ManagementPage_SortImageCount"
                                Click="SortBy_ImageCount"
                                GroupName="SortGroup">
                                <RadioMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B9;" />
                                </RadioMenuFlyoutItem.Icon>
                            </RadioMenuFlyoutItem>
                            <RadioMenuFlyoutItem
                                l:Localization.Uid="ManagementPage_SortGroupName"
                                Click="SortBy_Name"
                                GroupName="SortGroup">
                                <RadioMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8AC;" />
                                </RadioMenuFlyoutItem.Icon>
                            </RadioMenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <!--  Filter Dropdown  -->
                <DropDownButton
                    Grid.Column="2"
                    l:Localization.Uid="ManagementPage_FilterButton"
                    IsEnabled="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE71C;" />
                        <TextBlock>
                            <Run l:Localization.Uid="ManagementPage_FilterPrefix" />
                            <Run Text="{x:Bind ViewModel.CurrentFilterOptionDisplay, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <RadioMenuFlyoutItem
                                l:Localization.Uid="ManagementPage_FilterAll"
                                Click="FilterBy_All"
                                GroupName="FilterGroup"
                                IsChecked="True">
                                <RadioMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B9;" />
                                </RadioMenuFlyoutItem.Icon>
                            </RadioMenuFlyoutItem>
                            <RadioMenuFlyoutItem
                                l:Localization.Uid="ManagementPage_FilterExact"
                                Click="FilterBy_ExactMatchesOnly"
                                GroupName="FilterGroup">
                                <RadioMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE73E;" />
                                </RadioMenuFlyoutItem.Icon>
                            </RadioMenuFlyoutItem>
                            <RadioMenuFlyoutItem
                                l:Localization.Uid="ManagementPage_FilterSimilar"
                                Click="FilterBy_SimilarOnly"
                                GroupName="FilterGroup">
                                <RadioMenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE9D9;" />
                                </RadioMenuFlyoutItem.Icon>
                            </RadioMenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <!--  Separator  -->
                <Border
                    Grid.Column="3"
                    Width="1"
                    Margin="4,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!--  Spacer  -->
                <Border Grid.Column="4" />

                <!--  Similarity Threshold  -->
                <StackPanel
                    Grid.Column="5"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        l:Localization.Uid="ManagementPage_SimilarityThresholdLabel"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Slider
                        x:Name="SimilaritySlider"
                        Width="100"
                        VerticalAlignment="Center"
                        l:Localization.Uid="ManagementPage_SimilaritySlider"
                        Maximum="1.0"
                        Minimum="0.3"
                        StepFrequency="0.01"
                        ThumbToolTipValueConverter="{StaticResource SimilarityToPercentageConverter}"
                        Value="{x:Bind ViewModel.SimilarityThreshold, Mode=TwoWay}" />
                    <TextBlock
                        Width="40"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.SimilarityThreshold, Mode=OneWay, Converter={StaticResource SimilarityToPercentageConverter}}" />
                    <Button
                        l:Localization.Uid="ManagementPage_AnalyzeButton"
                        Command="{x:Bind ViewModel.AnalyzeSimilarityCommand}"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE9D9;" />
                            <TextBlock l:Localization.Uid="ManagementPage_AnalyzeText" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Separator  -->
                <Border
                    Grid.Column="6"
                    Width="1"
                    Margin="4,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <!--  Config Info  -->
                <StackPanel
                    Grid.Column="7"
                    Orientation="Horizontal"
                    Spacing="12">

                    <StackPanel
                        l:Localization.Uid="ManagementPage_ItemCountPanel"
                        Orientation="Horizontal"
                        Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon
                                FontSize="14"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE8B8;" />
                            <TextBlock
                                VerticalAlignment="Center"
                                l:Localization.Uid="ManagementPage_ModelNameText"
                                FontSize="12"
                                Text="{x:Bind ViewModel.ModelName, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon
                                FontSize="14"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE8B9;" />
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                <Run Text="{x:Bind ViewModel.TotalFileCount, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!--  Back to Config Button  -->
                    <Button l:Localization.Uid="ManagementPage_BackToConfigButton" Click="BackToConfiguration_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE72B;" />
                            <TextBlock l:Localization.Uid="ManagementPage_ConfigurationText" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Main Content  -->
        <Grid
            x:Name="SplitViewGrid"
            Grid.Row="1"
            Margin="10,10,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <!--  Left Panel - Cluster Grid  -->
            <Border
                Grid.Column="0"
                MinWidth="300"
                Padding="16"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <StackPanel
                        Grid.Row="0"
                        Margin="0,0,0,16"
                        Spacing="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="20" FontWeight="SemiBold">
                                    <Run l:Localization.Uid="ManagementPage_DuplicateGroupsHeader" />
                                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=" (" /><Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.DuplicateGroupsCount, Mode=OneWay}" /><Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=")" />
                                </TextBlock>
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.Status, Mode=OneWay}" />
                            </StackPanel>

                            <!--  View Toggle  -->
                            <controlsWinUI:Segmented
                                Grid.Column="2"
                                SelectedIndex="0"
                                SelectionChanged="ViewSegmented_SelectionChanged">
                                <controlsWinUI:SegmentedItem Tag="Grid">
                                    <FontIcon Foreground="{ThemeResource TextFillColorTertiaryBrush}" Glyph="&#xF0E2;" />
                                </controlsWinUI:SegmentedItem>
                                <controlsWinUI:SegmentedItem Tag="List">
                                    <FontIcon Foreground="{ThemeResource TextFillColorTertiaryBrush}" Glyph="&#xE8FD;" />
                                </controlsWinUI:SegmentedItem>
                            </controlsWinUI:Segmented>
                        </Grid>

                        <!--  Analysis Progress Bar  -->
                        <Grid Visibility="{x:Bind ViewModel.IsAnalyzingSimilarity, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ProgressBar
                                Grid.Column="0"
                                Height="8"
                                Margin="0,0,8,0"
                                IsIndeterminate="False"
                                Maximum="100"
                                Minimum="0"
                                Value="{x:Bind ViewModel.AnalysisProgressPercentage, Mode=OneWay}" />

                            <TextBlock
                                Grid.Column="1"
                                MinWidth="40"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.AnalysisProgressPercentage, Mode=OneWay, Converter={StaticResource PercentageConverter}}" />

                            <!--  Cancel Button  -->
                            <Button
                                Grid.Column="2"
                                Margin="4,0,0,0"
                                Padding="6"
                                VerticalAlignment="Center"
                                l:Localization.Uid="ManagementPage_CancelAnalysisButton"
                                Command="{x:Bind ViewModel.CancelAnalysisCommand}"
                                Style="{StaticResource SubtleButtonStyle}">
                                <FontIcon
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Glyph="&#xE711;" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!--  Empty State  -->
                    <StackPanel
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay}">
                        <FontIcon
                            FontSize="64"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Glyph="&#xE8B9;" />
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <TextBlock
                                HorizontalAlignment="Center"
                                l:Localization.Uid="ManagementPage_EmptyStateTitle"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                l:Localization.Uid="ManagementPage_EmptyStateSubtitle"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                TextAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!--  Group Grid View  -->
                    <Grid Grid.Row="1" Visibility="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}">
                        <GridView
                            Grid.Row="1"
                            IsItemClickEnabled="True"
                            ItemsSource="{x:Bind ViewModel.SimilarityGroups, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}"
                            SelectionMode="Single"
                            Visibility="{x:Bind ViewModel.IsGridView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <GridView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource DefaultGridViewItemStyle}" TargetType="GridViewItem">
                                    <Setter Property="Margin" Value="4" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:SimilarityGroup">
                                    <controls:ImageGroupCard Group="{x:Bind}" />
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <!--  Group List View  -->
                        <ListView
                            Grid.Row="1"
                            IsItemClickEnabled="True"
                            ItemsSource="{x:Bind ViewModel.SimilarityGroups, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}"
                            SelectionMode="Single"
                            Visibility="{x:Bind ViewModel.IsListView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,2" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:SimilarityGroup">
                                    <controls:ImageGroupListItem Group="{x:Bind}" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>

            <!--  GridSplitter  -->
            <splitter:GridSplitter
                x:Name="GroupContentSplitter"
                Grid.Column="1"
                Width="1"
                HorizontalAlignment="Center"
                Background="Transparent"
                Foreground="Transparent"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Auto"
                Style="{StaticResource CustomGridSplitterStyle}"
                Visibility="{x:Bind ViewModel.SelectedGroup, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

            <!--  Right Panel - Group Content  -->
            <Border
                x:Name="GroupContentPanel"
                Grid.Column="2"
                MinWidth="400"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Opacity="0"
                Visibility="{x:Bind ViewModel.SelectedGroup, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="GroupContentPanelTransform" X="400" />
                </Border.RenderTransform>

                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Editable Group Name  -->
                        <Grid Grid.Column="0">
                            <!--  Display Mode  -->
                            <StackPanel
                                x:Name="GroupNameDisplayPanel"
                                Orientation="Horizontal"
                                Spacing="8">
                                <TextBlock
                                    x:Name="GroupNameTextBlock"
                                    Padding="0,3.5"
                                    VerticalAlignment="Center"
                                    l:Localization.Uid="ManagementPage_GroupNameDisplay"
                                    DoubleTapped="GroupNameTextBlock_DoubleTapped"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.SelectedGroup.Name, Mode=OneWay}" />
                                <Button
                                    x:Name="EditGroupNameButton"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    l:Localization.Uid="ManagementPage_RenameGroupButton"
                                    Click="EditGroupNameButton_Click"
                                    Style="{StaticResource SubtleButtonStyle}">
                                    <FontIcon FontSize="12" Glyph="&#xE70F;" />
                                </Button>
                            </StackPanel>

                            <!--  Edit Mode  -->
                            <StackPanel
                                x:Name="GroupNameEditPanel"
                                Orientation="Horizontal"
                                Spacing="4"
                                Visibility="Collapsed">
                                <TextBox
                                    x:Name="GroupNameTextBox"
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    l:Localization.Uid="ManagementPage_GroupNameTextBox"
                                    FontSize="16"
                                    KeyDown="GroupNameTextBox_KeyDown"
                                    LostFocus="GroupNameTextBox_LostFocus" />
                                <Button
                                    x:Name="ConfirmRenameButton"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    l:Localization.Uid="ManagementPage_ConfirmRenameButton"
                                    Click="ConfirmRenameButton_Click"
                                    Style="{StaticResource AccentButtonStyle}">
                                    <FontIcon FontSize="12" Glyph="&#xE8FB;" />
                                </Button>
                                <Button
                                    x:Name="CancelRenameButton"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    l:Localization.Uid="ManagementPage_CancelRenameButton"
                                    Click="CancelRenameButton_Click"
                                    Style="{StaticResource SubtleButtonStyle}">
                                    <FontIcon FontSize="12" Glyph="&#xE711;" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!--  Close Button  -->
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            l:Localization.Uid="ManagementPage_CloseDetailsButton"
                            Click="CloseGroupContentPanel_Click"
                            Style="{StaticResource SubtleButtonStyle}">
                            <FontIcon FontSize="16" Glyph="&#xE711;" />
                        </Button>
                    </Grid>

                    <!--  Selection Controls  -->
                    <Border
                        Grid.Row="1"
                        Padding="12"
                        Background="{ThemeResource LayerFillColorAltBrush}"
                        CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Select All Checkbox  -->
                            <CheckBox
                                x:Name="SelectAllCheckBox"
                                Grid.Column="0"
                                MinWidth="0"
                                MinHeight="0"
                                VerticalAlignment="Center"
                                l:Localization.Uid="ManagementPage_SelectAllGroupCheckBox"
                                Click="SelectAllGroupCheckBox_Click"
                                IsThreeState="True" />

                            <!--  Selection Count  -->
                            <TextBlock
                                x:Name="SelectionCountText"
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <!--  Auto-Select Dropdown  -->
                            <DropDownButton Grid.Column="2" l:Localization.Uid="ManagementPage_AutoSelectGroupButton">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xF16E;" />
                                    <TextBlock l:Localization.Uid="ManagementPage_AutoSelectText" />
                                </StackPanel>
                                <DropDownButton.Flyout>
                                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                                        <MenuFlyoutSubItem l:Localization.Uid="ManagementPage_ByResolution">
                                            <MenuFlyoutSubItem.Icon>
                                                <FontIcon Glyph="&#xE9E9;" />
                                            </MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepHighestResolution" Click="ApplyStrategy_KeepHighestResolution">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE9E9;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepLowestResolution" Click="ApplyStrategy_KeepLowestResolution">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE9E9;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyoutSubItem>

                                        <MenuFlyoutSubItem l:Localization.Uid="ManagementPage_ByFileSize">
                                            <MenuFlyoutSubItem.Icon>
                                                <FontIcon Glyph="&#xE729;" />
                                            </MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepLargestFileSize" Click="ApplyStrategy_KeepLargestFileSize">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE729;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepSmallestFileSize" Click="ApplyStrategy_KeepSmallestFileSize">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE729;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyoutSubItem>

                                        <MenuFlyoutSubItem l:Localization.Uid="ManagementPage_ByDate">
                                            <MenuFlyoutSubItem.Icon>
                                                <FontIcon Glyph="&#xE787;" />
                                            </MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepNewest" Click="ApplyStrategy_KeepNewest">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE823;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem l:Localization.Uid="SelectionStrategy_KeepOldest" Click="ApplyStrategy_KeepOldest">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74B;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyoutSubItem>
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </Grid>
                    </Border>

                    <!--  Image Cards Grid  -->
                    <ScrollViewer Grid.Row="2">
                        <ItemsRepeater x:Name="ImageCardsRepeater" ItemsSource="{x:Bind ViewModel.SelectedGroup.SelectableItems, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout
                                    ItemsStretch="None"
                                    MinColumnSpacing="8"
                                    MinItemHeight="240"
                                    MinItemWidth="180"
                                    MinRowSpacing="8"
                                    Orientation="Horizontal" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:SelectableItem">
                                    <controls:ImageDetailCard SelectableItem="{x:Bind}" />
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!--  Bottom Action Bar  -->
        <Border
            Grid.Row="2"
            Margin="10,0,10,10"
            Padding="16,12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            CornerRadius="8"
            Visibility="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Left Side - Selection Summary  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="16">

                    <!--  Selection Info  -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon
                            FontSize="18"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Glyph="&#xE73E;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            Text="{x:Bind ViewModel.SelectionSummary, Mode=OneWay}" />
                    </StackPanel>

                    <!--  Clear All Button  -->
                    <Button
                        l:Localization.Uid="ManagementPage_ClearAllSelectionsButton"
                        Click="ClearAllSelections_Click"
                        Style="{StaticResource SubtleButtonStyle}"
                        Visibility="{x:Bind ViewModel.HasAnySelectedItems, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="12" Glyph="&#xE711;" />
                            <TextBlock l:Localization.Uid="ManagementPage_ClearAllText" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Right Side - Action Buttons  -->
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">

                    <!--  Copy  -->
                    <DropDownButton l:Localization.Uid="ManagementPage_CopyDropDown" IsEnabled="{x:Bind ViewModel.CanMoveOrCopy, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                            <TextBlock l:Localization.Uid="ManagementPage_CopyText" />
                        </StackPanel>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem l:Localization.Uid="ManagementPage_CopyToOneFolder" Click="CopyToSingleFolder_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8C8;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem l:Localization.Uid="ManagementPage_CopyToGroupFolders" Click="CopyToGroupFolders_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xF413;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <!--  Move  -->
                    <DropDownButton l:Localization.Uid="ManagementPage_MoveDropDown" IsEnabled="{x:Bind ViewModel.CanMoveOrCopy, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE8C6;" />
                            <TextBlock l:Localization.Uid="ManagementPage_MoveText" />
                        </StackPanel>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem l:Localization.Uid="ManagementPage_MoveToOneFolder" Click="MoveToSingleFolder_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8DE;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem l:Localization.Uid="ManagementPage_MoveToGroupFolders" Click="MoveToGroupFolders_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xF413;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <!--  Separator  -->
                    <Border
                        Width="1"
                        Margin="4,4"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!--  Delete Button  -->
                    <SplitButton
                        x:Name="DeleteSelectedButton"
                        l:Localization.Uid="ManagementPage_DeleteSplitButton"
                        Click="DeleteSplitButton_Click"
                        IsEnabled="{x:Bind ViewModel.HasAnySelectedItems, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                            <TextBlock>
                                <Run l:Localization.Uid="ManagementPage_DeleteLabel" />
                                <Run Text="(" /><Run Text="{x:Bind ViewModel.TotalSelectedCount, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                        <SplitButton.Flyout>
                            <MenuFlyout Placement="Top">
                                <MenuFlyoutItem l:Localization.Uid="ManagementPage_MoveToRecycleBin" Click="DeleteToRecycleBin_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem l:Localization.Uid="ManagementPage_DeletePermanently" Click="DeletePermanently_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE894;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>