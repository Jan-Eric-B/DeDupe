<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Pages.ManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DeDupe.Controls"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DeDupe.Models.Analysis"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    xmlns:splitter="using:CommunityToolkit.WinUI.Controls"
    d:DataContext="{d:DesignInstance Type=pages:ManagementViewModel}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <converters:SimilarityToPercentageConverter x:Key="SimilarityToPercentageConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:DoubleFormatConverter x:Key="DoubleFormatConverter" />
        <Style x:Key="CustomGridSplitterStyle" TargetType="splitter:GridSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="splitter:GridSplitter">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.4*" />
                                    <RowDefinition Height="0.2*" />
                                    <RowDefinition Height="0.4*" />
                                </Grid.RowDefinitions>

                                <Rectangle
                                    x:Name="GripperBar"
                                    Grid.Row="1"
                                    Width="4"
                                    Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    Opacity="0.3"
                                    RadiusX="2"
                                    RadiusY="2" />
                            </Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="GripperBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="GripperBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Name="ShowGroupContentPanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanelTransform"
                Storyboard.TargetProperty="X"
                To="0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanel"
                Storyboard.TargetProperty="Opacity"
                To="1"
                Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Name="HideGroupContentPanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanelTransform"
                Storyboard.TargetProperty="X"
                To="400"
                Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanel"
                Storyboard.TargetProperty="Opacity"
                To="0"
                Duration="0:0:0.25" />
        </Storyboard>
    </Page.Resources>

    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <Border
            Grid.Row="0"
            Margin="10,0"
            Padding="16,12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            CornerRadius="8">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Left  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10" />

                <!--  Right - Config Info  -->
                <Border
                    Grid.Column="3"
                    Padding="0"
                    CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <!--  Model Info  -->
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon
                                FontSize="16"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE8B8;" />
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.ModelName, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>

                        <!--  Files Count  -->
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon
                                FontSize="16"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE8B7;" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.TotalFileCount, Mode=OneWay}" />
                                <Run Text="files" />
                            </TextBlock>
                        </StackPanel>

                        <!--  Vertical Divider  -->
                        <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <!--  Similarity Analysis Button  -->
                        <Button>
                            <Button.Content>
                                <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="Analyze Similarity" />
                                    <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.SimilarityThreshold, Mode=OneWay, Converter={StaticResource DoubleFormatConverter}, ConverterParameter=2}" />
                                    <Run Text="%" />
                                </TextBlock>
                            </Button.Content>
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Width="280" Spacing="10">
                                        <TextBlock FontSize="16" FontWeight="SemiBold">
                                            <Run Text="Similarity Threshold:" />
                                            <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.SimilarityThreshold, Mode=OneWay, Converter={StaticResource DoubleFormatConverter}, ConverterParameter=2}" />
                                            <Run Text="%" />
                                        </TextBlock>
                                        <Slider
                                            x:Name="SimilaritySlider"
                                            Maximum="1.0"
                                            Minimum="0.3"
                                            StepFrequency="0.01"
                                            TickFrequency="0.1"
                                            ToolTipService.ToolTip="How similar images must be to be grouped."
                                            Value="{x:Bind ViewModel.SimilarityThreshold, Mode=TwoWay}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="Higher values = more strict matching"
                                            TextWrapping="Wrap" />

                                        <StackPanel
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal"
                                            Spacing="10">
                                            <ProgressRing
                                                Width="24"
                                                Height="24"
                                                IsActive="{x:Bind ViewModel.IsAnalyzingSimilarity, Mode=OneWay}" />
                                            <Button
                                                Command="{x:Bind ViewModel.AnalyzeSimilarityCommand}"
                                                Content="Analyze"
                                                IsEnabled="{x:Bind ViewModel.CanStartSimilarityAnalysis, Mode=OneWay}"
                                                Style="{StaticResource AccentButtonStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!--  Back to Config Button  -->
                        <Button Click="BackToConfiguration_Click">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon FontSize="14" Glyph="&#xE713;" />
                                    <TextBlock Text="Configuration" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!--  Content  -->
        <Grid Grid.Row="1" Margin="10">
            <!--  Empty State - No Results  -->
            <Border
                Padding="40"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
                    <FontIcon
                        HorizontalAlignment="Center"
                        FontSize="64"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Glyph="&#xE946;" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="No Results" />
                    <TextBlock
                        MaxWidth="300"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="Click 'Analyze' to find and group similar images"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!--  Found Results  -->
            <Grid x:Name="SplitViewGrid" Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="0" />
                    <ColumnDefinition Width="0" />
                </Grid.ColumnDefinitions>

                <!--  Left Panel - Cluster Groups List  -->
                <Border
                    Grid.Column="0"
                    MinWidth="300"
                    Padding="10,5"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Results Summary Header  -->
                        <StackPanel
                            Grid.Row="0"
                            Margin="0,0,0,16"
                            Spacing="5">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="Duplicate Groups" />
                            <TextBlock
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.ResultSummary, Mode=OneWay}" />
                        </StackPanel>

                        <!--  Groups Grid  -->
                        <ScrollViewer Grid.Row="1">
                            <GridView
                                IsItemClickEnabled="True"
                                ItemClick="ClusterGrid_ItemClick"
                                ItemsSource="{x:Bind ViewModel.ClusterGroups, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedCluster, Mode=TwoWay}"
                                SelectionMode="Single">
                                <GridView.ItemContainerStyle>
                                    <Style BasedOn="{StaticResource DefaultGridViewItemStyle}" TargetType="GridViewItem">
                                        <Setter Property="Margin" Value="0,0,10,10" />
                                    </Style>
                                </GridView.ItemContainerStyle>
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ImageCluster">
                                        <Border
                                            Width="200"
                                            Height="240"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <Grid Padding="12">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!--  Image Preview  -->
                                                <Grid Grid.Row="0">
                                                    <controls:StackedImagesControl
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        ImagePaths="{x:Bind GetPreviewImagePaths()}" />

                                                    <!--  Selection Checkbox  -->
                                                    <CheckBox
                                                        x:Name="SelectionCheckBox"
                                                        MinWidth="0"
                                                        MinHeight="0"
                                                        Margin="4"
                                                        Padding="0"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        CornerRadius="4" />
                                                </Grid>

                                                <!--  Group Info  -->
                                                <StackPanel Grid.Row="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0" Spacing="4">
                                                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                                <Run FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                            </TextBlock>

                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                <FontIcon
                                                                    FontSize="16"
                                                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                                    Glyph="&#xE8B9;" />
                                                                <TextBlock
                                                                    FontSize="18"
                                                                    FontWeight="Bold"
                                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                                                                    <Run Text="{x:Bind Count}" />
                                                                    <Run
                                                                        FontSize="14"
                                                                        FontWeight="SemiBold"
                                                                        Text=" images" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!--  Similarity  -->
                                                        <Border
                                                            Grid.Column="1"
                                                            Padding="8,4"
                                                            VerticalAlignment="Bottom"
                                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                            CornerRadius="4">
                                                            <StackPanel Orientation="Horizontal" Spacing="2">
                                                                <TextBlock
                                                                    FontSize="14"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="White"
                                                                    Text="{x:Bind AverageSimilarity, Converter={StaticResource SimilarityToPercentageConverter}}" />
                                                                <TextBlock
                                                                    FontSize="14"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="White"
                                                                    Text="%" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!--  GridSplitter  -->
                <splitter:GridSplitter
                    x:Name="GroupContentSplitter"
                    Grid.Column="1"
                    Width="16"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    ResizeBehavior="BasedOnAlignment"
                    ResizeDirection="Auto"
                    Style="{StaticResource CustomGridSplitterStyle}"
                    Visibility="{x:Bind ViewModel.SelectedCluster, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

                <!--  Right Panel - Group Content  -->
                <Border
                    x:Name="GroupContentPanel"
                    Grid.Column="2"
                    MinWidth="300"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Opacity="0"
                    Visibility="{x:Bind ViewModel.SelectedCluster, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="GroupContentPanelTransform" X="400" />
                    </Border.RenderTransform>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Header  -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" FontSize="18">
                                <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedCluster.Name, Mode=OneWay}" />
                            </TextBlock>

                            <Button
                                Grid.Column="1"
                                Click="CloseGroupContentPanel_Click"
                                Style="{StaticResource SubtleButtonStyle}"
                                ToolTipService.ToolTip="Close details">
                                <FontIcon FontSize="16" Glyph="&#xE711;" />
                            </Button>
                        </Grid>

                        <!--  Group Content  -->
                        <ScrollViewer Grid.Row="1">
                            <StackPanel Spacing="16" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>