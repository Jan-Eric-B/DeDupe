<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Pages.ManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DeDupe.Controls"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DeDupe.Models.Analysis"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    xmlns:splitter="using:CommunityToolkit.WinUI.Controls"
    d:DataContext="{d:DesignInstance Type=pages:ManagementViewModel}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <converters:SimilarityToPercentageConverter x:Key="SimilarityToPercentageConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:DoubleFormatConverter x:Key="DoubleFormatConverter" />
        <Style x:Key="CustomGridSplitterStyle" TargetType="splitter:GridSplitter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="splitter:GridSplitter">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.4*" />
                                    <RowDefinition Height="0.2*" />
                                    <RowDefinition Height="0.4*" />
                                </Grid.RowDefinitions>

                                <Rectangle
                                    x:Name="GripperBar"
                                    Grid.Row="1"
                                    Width="4"
                                    Fill="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    Opacity="0.3"
                                    RadiusX="2"
                                    RadiusY="2" />
                            </Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="GripperBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="GripperBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Name="ShowGroupContentPanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanelTransform"
                Storyboard.TargetProperty="X"
                To="0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanel"
                Storyboard.TargetProperty="Opacity"
                To="1"
                Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Name="HideGroupContentPanelStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanelTransform"
                Storyboard.TargetProperty="X"
                To="400"
                Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="GroupContentPanel"
                Storyboard.TargetProperty="Opacity"
                To="0"
                Duration="0:0:0.25" />
        </Storyboard>
    </Page.Resources>

    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Toolbar  -->
        <Border
            Grid.Row="0"
            Margin="10,0"
            Padding="16,12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            CornerRadius="8">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Left  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10" />

                <!--  Right - Config Info  -->
                <Border
                    Grid.Column="3"
                    Padding="0"
                    CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <!--  Model Info  -->
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon
                                FontSize="16"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE8B8;" />
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.ModelName, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>

                        <!--  Files Count  -->
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon
                                FontSize="16"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE8B7;" />
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.TotalFileCount, Mode=OneWay}" />
                                <Run Text="files" />
                            </TextBlock>
                        </StackPanel>

                        <!--  Features Count  -->
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon
                                FontSize="16"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Glyph="&#xE9D9;" />
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.ExtractedFeaturesCount, Mode=OneWay}" />
                                <Run Text="features" />
                            </TextBlock>
                        </StackPanel>

                        <!--  Back to Config Button  -->
                        <Button Click="BackToConfiguration_Click">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon FontSize="14" Glyph="&#xE713;" />
                                    <TextBlock Text="Configuration" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!--  Main Content Area  -->
        <Grid
            x:Name="SplitViewGrid"
            Grid.Row="1"
            Margin="10,10,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <!--  Left Panel - Cluster Grid  -->
            <Border
                Grid.Column="0"
                MinWidth="300"
                Padding="10,5"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock FontSize="20" FontWeight="SemiBold">
                                <Run Text="Duplicate Groups" />
                                <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="(" /><Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.DuplicateGroupsCount, Mode=OneWay}" /><Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text=")" />
                            </TextBlock>
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.Status, Mode=OneWay}" />
                        </StackPanel>

                        <!--  Similarity Threshold  -->
                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock VerticalAlignment="Center" Text="Similarity Threshold:" />
                                <Slider
                                    x:Name="SimilaritySlider"
                                    Width="120"
                                    VerticalAlignment="Center"
                                    Maximum="1.0"
                                    Minimum="0.3"
                                    StepFrequency="0.01"
                                    ThumbToolTipValueConverter="{StaticResource SimilarityToPercentageConverter}"
                                    ToolTipService.ToolTip="How similar images must be to be grouped."
                                    Value="{x:Bind ViewModel.SimilarityThreshold, Mode=TwoWay}" />
                                <TextBlock
                                    Width="50"
                                    VerticalAlignment="Center"
                                    Text="{x:Bind ViewModel.SimilarityThreshold, Mode=OneWay, Converter={StaticResource SimilarityToPercentageConverter}}" />
                            </StackPanel>

                            <Button
                                Command="{x:Bind ViewModel.AnalyzeSimilarityCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                ToolTipService.ToolTip="Higher values = more strict matching">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE9D9;" />
                                    <TextBlock Text="Analyze" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!--  Empty State  -->
                    <StackPanel
                        Grid.Row="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay}">
                        <FontIcon
                            FontSize="64"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Glyph="&#xE8B9;" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Click Analyze to find duplicate groups"
                            TextAlignment="Center" />
                    </StackPanel>

                    <!--  Cluster Grid  -->
                    <ScrollViewer Grid.Row="2" Visibility="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}">
                        <GridView
                            IsItemClickEnabled="True"
                            ItemsSource="{x:Bind ViewModel.ClusterGroups, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedCluster, Mode=TwoWay}"
                            SelectionMode="Single">
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:ImageCluster">
                                    <Border
                                        Width="280"
                                        Height="260"
                                        Margin="4"
                                        Padding="10"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Grid RowSpacing="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!--  Stacked Images  -->
                                            <Grid Grid.Row="0">
                                                <controls:StackedImagesControl
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    ImagePaths="{x:Bind GetPreviewImagePaths()}" />

                                                <!--  Group Selection Checkbox  -->
                                                <CheckBox
                                                    x:Name="GroupSelectionCheckBox"
                                                    MinWidth="0"
                                                    MinHeight="0"
                                                    Margin="4"
                                                    Padding="0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    CornerRadius="4"
                                                    IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                            </Grid>

                                            <!--  Group Info  -->
                                            <StackPanel Grid.Row="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind Name, Mode=OneWay}" />
                                                        </TextBlock>

                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <FontIcon
                                                                FontSize="16"
                                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                                Glyph="&#xE8B9;" />
                                                            <TextBlock
                                                                FontSize="18"
                                                                FontWeight="Bold"
                                                                Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                                                                <Run Text="{x:Bind Count}" />
                                                                <Run
                                                                    FontSize="14"
                                                                    FontWeight="SemiBold"
                                                                    Text=" images" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!--  Similarity  -->
                                                    <Border
                                                        Grid.Column="1"
                                                        Padding="8,4"
                                                        VerticalAlignment="Bottom"
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="4">
                                                        <TextBlock
                                                            FontSize="14"
                                                            FontWeight="SemiBold"
                                                            Foreground="White"
                                                            Text="{x:Bind AverageSimilarity, Converter={StaticResource SimilarityToPercentageConverter}}" />
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!--  GridSplitter  -->
            <splitter:GridSplitter
                x:Name="GroupContentSplitter"
                Grid.Column="1"
                Width="16"
                HorizontalAlignment="Center"
                Background="Transparent"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Auto"
                Style="{StaticResource CustomGridSplitterStyle}"
                Visibility="{x:Bind ViewModel.SelectedCluster, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}" />

            <!--  Right Panel - Group Content  -->
            <Border
                x:Name="GroupContentPanel"
                Grid.Column="2"
                MinWidth="400"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Opacity="0"
                Visibility="{x:Bind ViewModel.SelectedCluster, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="GroupContentPanelTransform" X="400" />
                </Border.RenderTransform>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Editable Group Name  -->
                        <Grid Grid.Column="0">
                            <!--  Display Mode  -->
                            <StackPanel
                                x:Name="GroupNameDisplayPanel"
                                Orientation="Horizontal"
                                Spacing="8">
                                <TextBlock
                                    x:Name="GroupNameTextBlock"
                                    Padding="0,5"
                                    VerticalAlignment="Center"
                                    DoubleTapped="GroupNameTextBlock_DoubleTapped"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.SelectedCluster.Name, Mode=OneWay}"
                                    ToolTipService.ToolTip="Double-click to rename" />
                                <Button
                                    x:Name="EditGroupNameButton"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    Click="EditGroupNameButton_Click"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Rename group">
                                    <FontIcon FontSize="12" Glyph="&#xE70F;" />
                                </Button>
                            </StackPanel>

                            <!--  Edit Mode  -->
                            <StackPanel
                                x:Name="GroupNameEditPanel"
                                Orientation="Horizontal"
                                Spacing="4"
                                Visibility="Collapsed">
                                <TextBox
                                    x:Name="GroupNameTextBox"
                                    MinWidth="200"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    KeyDown="GroupNameTextBox_KeyDown"
                                    LostFocus="GroupNameTextBox_LostFocus"
                                    PlaceholderText="Enter group name" />
                                <Button
                                    x:Name="ConfirmRenameButton"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    Click="ConfirmRenameButton_Click"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="Confirm (Enter)">
                                    <FontIcon FontSize="12" Glyph="&#xE8FB;" />
                                </Button>
                                <Button
                                    x:Name="CancelRenameButton"
                                    Padding="6"
                                    VerticalAlignment="Center"
                                    Click="CancelRenameButton_Click"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Cancel (Escape)">
                                    <FontIcon FontSize="12" Glyph="&#xE711;" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!--  Close Button  -->
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Top"
                            Click="CloseGroupContentPanel_Click"
                            Style="{StaticResource SubtleButtonStyle}"
                            ToolTipService.ToolTip="Close details">
                            <FontIcon FontSize="16" Glyph="&#xE711;" />
                        </Button>
                    </Grid>

                    <!--  Selection Controls Bar  -->
                    <Border
                        Grid.Row="1"
                        Margin="0,0,0,12"
                        Padding="12,8"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  Select All Checkbox  -->
                            <StackPanel
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8">
                                <CheckBox
                                    x:Name="SelectAllCheckBox"
                                    MinWidth="0"
                                    MinHeight="0"
                                    VerticalAlignment="Center"
                                    Checked="SelectAllCheckBox_Changed"
                                    IsChecked="{x:Bind ViewModel.SelectedCluster.IsSelected, Mode=TwoWay}"
                                    Unchecked="SelectAllCheckBox_Changed" />
                                <TextBlock VerticalAlignment="Center" FontSize="13">
                                    <Run Text="{x:Bind ViewModel.SelectedCluster.SelectedCount, Mode=OneWay}" />
                                    <Run Text=" of " />
                                    <Run Text="{x:Bind ViewModel.SelectedCluster.Count, Mode=OneWay}" />
                                    <Run Text=" selected" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Image Cards Grid  -->
                    <ScrollViewer Grid.Row="2">
                        <ItemsRepeater x:Name="ImageCardsRepeater" ItemsSource="{x:Bind ViewModel.SelectedCluster.SelectableImages, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout
                                    ItemsStretch="None"
                                    MinColumnSpacing="8"
                                    MinItemHeight="220"
                                    MinItemWidth="180"
                                    MinRowSpacing="8"
                                    Orientation="Horizontal" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:SelectableImage">
                                    <controls:ImageDetailCard IsSelected="{x:Bind IsSelected, Mode=TwoWay}" SelectableImage="{x:Bind}" />
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>