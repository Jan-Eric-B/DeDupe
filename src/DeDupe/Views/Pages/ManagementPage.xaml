<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeDupe.Views.Pages.ManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    d:DataContext="{d:DesignInstance Type=pages:ManagementViewModel}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
    </Page.Resources>

    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Margin="10,0"
                CornerRadius="8"
                Padding="16,12">
            <Grid ColumnSpacing="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <!-- Similarity Controls -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">

                    <TextBlock Text="Similarity Threshold:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />

                    <Slider Width="150"
                            Minimum="0.5"
                            Maximum="1.0"
                            Value="{x:Bind ViewModel.SimilarityThreshold, Mode=TwoWay}"
                            StepFrequency="0.01"
                            TickFrequency="0.1"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="How similar images must be to be grouped." />

                    <Button Content="Analyze"
                            Command="{x:Bind ViewModel.AnalyzeSimilarityCommand}"
                            IsEnabled="{x:Bind ViewModel.CanStartSimilarityAnalysis, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}"
                            VerticalAlignment="Center" />
                    <ProgressRing IsActive="{x:Bind ViewModel.IsAnalyzingSimilarity, Mode=OneWay}"
                                  Width="24"
                                  Height="24" />
                </StackPanel>

                <!-- Back Button -->
                <Button Grid.Column="1"
                        Content="Back to Configuration"
                        HorizontalAlignment="Right"
                        Click="BackToConfiguration_Click" />
            </Grid>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1"
                Margin="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="40">

            <Grid>
                <!-- Initial State -->
                <StackPanel Spacing="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                </StackPanel>

                <!-- Results Display -->
                <StackPanel Spacing="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.HasSimilarityResults, Mode=OneWay}">
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>