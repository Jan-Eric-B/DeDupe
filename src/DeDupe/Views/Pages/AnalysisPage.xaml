<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DeDupe.Views.Pages.AnalysisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    d:DataContext="{d:DesignInstance Type=pages:AnalysisViewModel}"
    mc:Ignorable="d">

    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Margin="5,0" Text="{x:Bind ViewModel.Title, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Border Grid.Column="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                VerticalAlignment="Stretch">
                <StackPanel Spacing="15">
                    <!-- Extracted Features Status -->
                    <StackPanel Spacing="5">
                        <TextBlock Text="Extracted Features" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="Feature vectors available:" />
                            <Run Text="{x:Bind ViewModel.ExtractedFeaturesCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Similarity Threshold Setting -->
                    <TextBlock Text="Similarity Threshold" FontWeight="SemiBold" FontSize="16" Margin="0,10,0,0" />

                    <TextBlock Text="How similar images must be to group together (0.0 - 1.0)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <!-- Slider -->
                        <Slider Grid.Column="0"
                            Minimum="0.5"
                            Maximum="1.0"
                            Value="{x:Bind ViewModel.SimilarityThreshold, Mode=TwoWay}"
                            StepFrequency="0.01"
                            TickFrequency="0.1"
                            TickPlacement="Outside" />

                        <!-- Number Box -->
                        <NumberBox Grid.Column="1"
                            Value="{x:Bind ViewModel.SimilarityThreshold, Mode=TwoWay}"
                            Minimum="0.5"
                            Maximum="1.0"
                            SpinButtonPlacementMode="Compact"
                            SmallChange="0.01"
                            LargeChange="0.05" />
                    </Grid>

                    <!-- Helper Text -->
                    <TextBlock FontSize="11"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        TextWrapping="Wrap">
                        <Run Text="Higher values: More strict grouping (fewer, more similar groups)" />
                        <LineBreak />
                        <Run Text="Lower values: More lenient grouping (more groups, less similar)" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Navigation Buttons -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <Button Content="Previous"
              Grid.Column="0"
              HorizontalAlignment="Left"
              Command="{x:Bind ViewModel.NavigateToPreviousCommand}" />

            <StackPanel Orientation="Horizontal"
                  Grid.Column="1"
                  Spacing="10"
                  HorizontalAlignment="Right">

                <!-- Progress and Status -->
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

                <TextBlock VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />

                <Button Content="Analyze Similarity"
                  Command="{x:Bind ViewModel.AnalyzeSimilarityCommand}"
                  IsEnabled="{x:Bind ViewModel.CanStartSimilarityAnalysis, Mode=OneWay}"
                  Style="{StaticResource AccentButtonStyle}"
                  FontSize="13"
                  MinWidth="150" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>