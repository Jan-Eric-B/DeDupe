<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Pages.FileInputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:DeDupe.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:input="using:DeDupe.Models.Input"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DeDupe.Models"
    xmlns:pages="using:DeDupe.ViewModels.Pages"
    d:DataContext="{d:DesignInstance Type=pages:FileInputViewModel}"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Page.Resources>
    <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title  -->
        <StackPanel
            Grid.Row="0"
            Margin="5,0"
            Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Add multiple files or whole folders you want to scan for duplicates and similar images."
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  Item List  -->
        <ListView
            x:Name="lvMediaSelectionList"
            Grid.Row="1"
            Padding="0,5"
            AllowDrop="True"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            DragOver="LvMediaSelectionList_DragOver"
            Drop="LvMediaSelectionList_Drop"
            ItemsSource="{x:Bind ViewModel.SourcePathItems, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="input:SourcePathItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Item Icon  -->
                        <FontIcon
                            Grid.Column="0"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Glyph="{x:Bind IconGlyph, Mode=OneWay}" />

                        <!--  Item Path  -->
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="{x:Bind Path}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap"
                            ToolTipService.ToolTip="{x:Bind Path}" />

                        <!--  Include Subdirectories Checkbox - Only visible for folders with subdirectories  -->
                        <CheckBox
                            Grid.Column="2"
                            Margin="10,0"
                            VerticalAlignment="Center"
                            Content="Include subfolders"
                            IsChecked="{x:Bind IncludeSubdirectories, Mode=TwoWay}"
                            ToolTipService.ToolTip="Scan all nested directories for images"
                            Visibility="{x:Bind ShowSubdirectoriesCheckbox}" />
                        <!--  Remove Button  -->

                        <Button
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ElementName=lvMediaSelectionList, Path=DataContext.RemoveItemCommand}"
                            CommandParameter="{Binding}"
                            IsEnabled="{Binding ElementName=lvMediaSelectionList, Path=DataContext.IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            ToolTipService.ToolTip="Remove item">
                            <FontIcon Glyph="&#xE74D;" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

            <!--  Empty state message  -->
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsHitTestVisible="False"
            Spacing="16"
            Visibility="{x:Bind ViewModel.IsMediaListEmpty, Mode=OneWay}">
            <FontIcon
                FontSize="72"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Glyph="&#xE8B7;" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Drag and drop files or folders here" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="or use the buttons below to select files" />
        </StackPanel>

        <!--  Navigation Buttons  -->
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="10">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.Status, Mode=OneWay}" />
            <Button
                x:Name="AddFolderButton"
                Command="{x:Bind ViewModel.AddFolderCommand}"
                Content="Add Folders"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            <Button
                x:Name="AddFilesButton"
                Command="{x:Bind ViewModel.AddFilesCommand}"
                Content="Add Files"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            <Button
                Command="{x:Bind ViewModel.NavigateToNextCommand}"
                Content="Next"
                IsEnabled="{x:Bind ViewModel.CanNavigateToNext, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Page>