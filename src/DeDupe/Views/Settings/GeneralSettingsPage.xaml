<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Settings.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:l="using:DeDupe.Localization"
    Background="Transparent"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Spacing="4">
            <TextBlock
                Margin="0,0,0,8"
                l:Localization.Uid="GeneralSettingsPage_Title"
                Style="{StaticResource TitleTextBlockStyle}" />

            <!--  Appearance  -->
            <TextBlock
                Margin="0,0,0,3"
                l:Localization.Uid="GeneralSettingsPage_AppearanceHeader"
                Style="{StaticResource BodyStrongTextBlockStyle}" />

            <!--  Theme  -->
            <controls:SettingsCard l:Localization.Uid="GeneralSettingsPage_ThemeCard" HeaderIcon="{ui:FontIcon Glyph=&#xE793;}">
                <ComboBox
                    MinWidth="150"
                    VerticalAlignment="Center"
                    ItemsSource="{x:Bind ViewModel.ThemeOptions, Mode=OneWay}"
                    SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </controls:SettingsCard>

            <!--  Backdrop  -->
            <controls:SettingsCard l:Localization.Uid="GeneralSettingsPage_BackdropCard" HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                <ComboBox
                    MinWidth="150"
                    VerticalAlignment="Center"
                    ItemsSource="{x:Bind ViewModel.BackdropOptions, Mode=OneWay}"
                    SelectedIndex="{x:Bind ViewModel.SelectedBackdropIndex, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </controls:SettingsCard>

            <!--  Accent Color  -->
            <controls:SettingsCard l:Localization.Uid="GeneralSettingsPage_AccentColorCard" HeaderIcon="{ui:FontIcon Glyph=&#xE771;}">
                <ComboBox
                    MinWidth="150"
                    VerticalAlignment="Center"
                    ItemsSource="{x:Bind ViewModel.AccentColorOptions, Mode=OneWay}"
                    SelectedIndex="{x:Bind ViewModel.SelectedAccentColorIndex, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </controls:SettingsCard>

            <!--  Language  -->
            <TextBlock
                Margin="0,29,0,3"
                l:Localization.Uid="GeneralSettingsPage_LanguageHeader"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Language" />

            <controls:SettingsCard l:Localization.Uid="GeneralSettingsPage_LanguageCard" HeaderIcon="{ui:FontIcon Glyph=&#xE774;}">
                <ComboBox
                    MinWidth="150"
                    VerticalAlignment="Center"
                    ItemsSource="{x:Bind ViewModel.AvailableLanguages}"
                    SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}" />
            </controls:SettingsCard>

            <!--  Logging  -->
            <TextBlock
                Margin="0,29,0,3"
                l:Localization.Uid="GeneralSettingsPage_LoggingHeader"
                Style="{StaticResource BodyStrongTextBlockStyle}" />

            <!--  Log Folder  -->
            <controls:SettingsCard l:Localization.Uid="GeneralSettingsPage_LogFolderCard" HeaderIcon="{ui:FontIcon Glyph=&#xE838;}">
                <Button
                    HorizontalAlignment="Stretch"
                    l:Localization.Uid="GeneralSettingsPage_LogFolderButton"
                    Command="{x:Bind ViewModel.OpenLogFolderCommand}">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xED25;" />
                </Button>
            </controls:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>