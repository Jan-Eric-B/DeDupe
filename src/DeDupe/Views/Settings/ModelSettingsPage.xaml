<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DeDupe.Views.Settings.ModelSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:config="using:DeDupe.Models.Configuration"
    Background="Transparent"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel MaxWidth="1000" Spacing="4">
            <TextBlock
                Margin="0,0,0,8"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Model Configuration" />

            <!--  Model Source Toggle  -->
            <controls:SettingsCard
                Description="Switch between pre-configured models or your own ONNX file"
                Header="Model source"
                HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">
                <controls:Segmented x:Name="ModelSourceSegmented" SelectionChanged="ModelSourceSegmented_SelectionChanged">
                    <controls:SegmentedItem Content="Bundled" Tag="Bundled" />
                    <controls:SegmentedItem Content="Custom" Tag="Custom" />
                </controls:Segmented>
            </controls:SettingsCard>

            <!--  Bundled Model Selection  -->
            <StackPanel
                x:Name="BundledModelSection"
                Margin="0,8,0,0"
                Spacing="8"
                Visibility="{x:Bind ViewModel.UseBundledModel, Mode=OneWay}">

                <controls:SettingsCard
                    Description="{x:Bind ViewModel.SelectedModelDescription, Mode=OneWay}"
                    Header="Select model"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE74C;}">
                    <StackPanel>
                        <ComboBox
                            MinWidth="220"
                            ItemsSource="{x:Bind ViewModel.BundledModels}"
                            SelectedValue="{x:Bind ViewModel.SelectedBundledModelId, Mode=TwoWay}"
                            SelectedValuePath="Id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="config:BundledModelInfo">
                                    <TextBlock Text="{x:Bind DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock
                            Margin="48,0,0,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind ViewModel.SelectedModelAvailability, Mode=OneWay}" />
                    </StackPanel>
                </controls:SettingsCard>
            </StackPanel>

            <!--  Custom Model Selection  -->
            <StackPanel
                x:Name="CustomModelSection"
                Margin="0,8,0,0"
                Spacing="8"
                Visibility="{x:Bind ViewModel.UseCustomModel, Mode=OneWay}">

                <!--  File picker  -->
                <controls:SettingsCard
                    Description="Drag and drop, or click Browse to select your .onnx file"
                    Header="Model file"
                    HeaderIcon="{ui:FontIcon Glyph=&#xF003;}">
                    <Grid
                        x:Name="ModelFileDropGrid"
                        AllowDrop="True"
                        ColumnSpacing="8"
                        DragOver="ModelFileDropGrid_DragOver"
                        Drop="ModelFileDropGrid_Drop">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            MinWidth="280"
                            MinHeight="36"
                            Padding="12,0"
                            VerticalAlignment="Center"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{ThemeResource ControlCornerRadius}"
                            DoubleTapped="ModelFileTextBlock_DoubleTapped"
                            ToolTipService.ToolTip="{x:Bind ViewModel.CustomModelFilePath, Mode=OneWay}">
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.CustomFileName, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{ThemeResource TextFillColorSecondary}" />
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Border>

                        <Button
                            Grid.Column="1"
                            Command="{x:Bind ViewModel.SelectCustomModelFileCommand}"
                            Content="Browse"
                            Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                </controls:SettingsCard>

                <!--  Download links  -->
                <controls:SettingsCard
                    Description="Find compatible ONNX models from these repositories"
                    Header="Need a model?"
                    HeaderIcon="{ui:FontIcon Glyph=&#xE896;}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <HyperlinkButton Content="Hugging Face" NavigateUri="https://huggingface.co/webml/models-moved/tree/main" />
                        <HyperlinkButton Content="ONNX Model Zoo" NavigateUri="https://github.com/onnx/models/tree/main/validated/vision/classification/resnet/model" />
                    </StackPanel>
                </controls:SettingsCard>
            </StackPanel>

            <!--  Advanced Settings  -->
            <TextBlock
                Margin="0,28,0,8"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Advanced" />

            <controls:SettingsExpander
                Description="Configure image preprocessing. Auto-applied when selecting bundled models."
                Header="Normalization"
                HeaderIcon="{ui:FontIcon Glyph=&#xE9D9;}"
                IsExpanded="False">

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Command="{x:Bind ViewModel.ApplyModelNormalizationCommand}"
                        Content="Apply model defaults"
                        IsEnabled="{x:Bind ViewModel.UseBundledModel, Mode=OneWay}" />
                </StackPanel>

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Header="Mean (R, G, B)">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox
                                Width="110"
                                BorderBrush="Red"
                                LargeChange="0.01"
                                SmallChange="0.001"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.MeanR, Mode=TwoWay}" />
                            <NumberBox
                                Width="110"
                                BorderBrush="Green"
                                LargeChange="0.01"
                                SmallChange="0.001"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.MeanG, Mode=TwoWay}" />
                            <NumberBox
                                Width="110"
                                BorderBrush="Blue"
                                LargeChange="0.01"
                                SmallChange="0.001"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.MeanB, Mode=TwoWay}" />
                        </StackPanel>
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="Std Dev (R, G, B)">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox
                                Width="110"
                                BorderBrush="Red"
                                LargeChange="0.01"
                                SmallChange="0.001"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.StdR, Mode=TwoWay}" />
                            <NumberBox
                                Width="110"
                                BorderBrush="Green"
                                LargeChange="0.01"
                                SmallChange="0.001"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.StdG, Mode=TwoWay}" />
                            <NumberBox
                                Width="110"
                                BorderBrush="Blue"
                                LargeChange="0.01"
                                SmallChange="0.001"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.StdB, Mode=TwoWay}" />
                        </StackPanel>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</Page>